GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
SHEET_ID=your-google-sheet-id-here

# Sheet1 GID (usually 0 for the first sheet tab)
SHEET_GID=0

# Secret key for /admin page access (used as query param ?key=xxx)
STATS_SECRET=

# API key for protecting API routes (server-side validation)
API_SECRET=

# Public API key sent by the frontend (must match API_SECRET)
NEXT_PUBLIC_API_KEY=
